{
  "name": "sanity-rooms",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./server": {
      "development": "./src/server/index.ts",
      "source": "./src/server/index.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "development": "./src/client/index.ts",
      "source": "./src/client/index.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs",
      "default": "./dist/client/index.js"
    },
    "./testing": {
      "development": "./src/testing/index.ts",
      "source": "./src/testing/index.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs",
      "default": "./dist/testing/index.js"
    },
    "./react": {
      "development": "./src/react/index.ts",
      "source": "./src/react/index.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "default": "./dist/react/index.js"
    },
    "./vite": {
      "development": "./src/vite/index.ts",
      "source": "./src/vite/index.ts",
      "import": "./dist/vite/index.js",
      "require": "./dist/vite/index.cjs",
      "default": "./dist/vite/index.js"
    },
    "./transport/ws-client": {
      "development": "./src/transport/ws-client-transport.ts",
      "source": "./src/transport/ws-client-transport.ts",
      "import": "./dist/transport/ws-client-transport.js",
      "default": "./dist/transport/ws-client-transport.js"
    },
    "./transport/ws-server": {
      "development": "./src/transport/ws-server-transport.ts",
      "source": "./src/transport/ws-server-transport.ts",
      "import": "./dist/transport/ws-server-transport.js",
      "default": "./dist/transport/ws-server-transport.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pkg-utils build --strict --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sanity/diff-patch": "^6.0.0",
    "@sanity/mutator": "^5.17.1",
    "@sanity/sdk": "^2.8.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@sanity/client": "^7.17.0",
    "@sanity/pkg-utils": "^10.4.5",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.5.10",
    "react": "^19.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.0.18",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@sanity/client": "^7.17.0",
    "react": ">=18",
    "vite": ">=5",
    "ws": ">=8"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vite": { "optional": true },
    "ws": { "optional": true }
  }
}
